// This Pine Script™ source code is subject to the terms of the Mozilla Public License 2.0
// https://mozilla.org/MPL/2.0/
// © SMC Strategy - Step 2: Trade Quality (Discount Zone)
//
// Step 1: Cấu trúc thị trường (SH, SL, BoS, ChoCh) ✅
// Step 2: Xác định vùng Discount >= 50% (Trade Quality) ← NEW
//
// Trade Quality:
// - Uptrend: Giá hồi về >= 50% từ SH xuống SL (vùng Discount)
// - Downtrend: Giá hồi về >= 50% từ SL lên SH (vùng Premium)
//   → Nhưng theo logic SMC, trong downtrend ta SELL ở Premium >= 50%
//
// Fibonacci levels:
// - 0% = Swing High
// - 50% = Equilibrium
// - 100% = Swing Low

//@version=6
indicator("SMC Step 2 - Trade Quality v1", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=100)

// ══════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════
grp_struct = "═══ CẤU TRÚC THỊ TRƯỜNG ═══"
swingLen      = input.int(5, "Swing Length", minval=2, maxval=20, group=grp_struct)
showSwingHL   = input.bool(true, "Hiện Swing High / Low", group=grp_struct)
showBosChoch  = input.bool(true, "Hiện BoS / ChoCh", group=grp_struct)
showConfirm   = input.bool(true, "Hiện nến xác nhận", group=grp_struct)
showLevels    = input.bool(true, "Hiện đường chờ phá vỡ", group=grp_struct)

grp_ema = "═══ EMA ═══"
emaLen       = input.int(200, "EMA Length", minval=50, maxval=500, group=grp_ema)
emaColor     = input.color(color.new(#9c9c9c, 0), "Màu EMA", group=grp_ema)

grp_quality = "═══ TRADE QUALITY ═══"
showFibZone   = input.bool(true, "Hiện vùng Discount/Premium", group=grp_quality)
fibThreshold  = input.float(50.0, "Ngưỡng % (Discount/Premium)", minval=0, maxval=100, step=5, group=grp_quality)
showEQ        = input.bool(true, "Hiện đường Equilibrium (50%)", group=grp_quality)

grp_color = "═══ MÀU SẮC ═══"
colorSH        = input.color(color.new(#089981, 0), "Swing High", group=grp_color)
colorSL        = input.color(color.new(#F23645, 0), "Swing Low", group=grp_color)
colorBoS       = input.color(color.new(#2962FF, 0), "BoS", group=grp_color)
colorChoCh     = input.color(color.new(#FF6D00, 0), "ChoCh", group=grp_color)
colorDiscount  = input.color(color.new(#089981, 85), "Vùng Discount (Buy)", group=grp_color)
colorPremium   = input.color(color.new(#F23645, 85), "Vùng Premium (Sell)", group=grp_color)

// ══════════════════════════════════════════
// TRẠNG THÁI
// ══════════════════════════════════════════
var int trend = 0

var float lastSH    = na
var int   lastSHBar = na
var float prevSH    = na
var int   prevSHBar = na

var float lastSL    = na
var int   lastSLBar = na
var float prevSL    = na
var int   prevSLBar = na

// Phá vỡ + chờ pullback
var bool  waitPullbackUp      = false
var float brokenUpLevel       = na
var int   brokenUpBar         = na
var float peakAfterBreakUp    = na
var int   peakAfterBreakUpBar = na
var bool  isChochUp           = false

var bool  waitPullbackDn         = false
var float brokenDnLevel          = na
var int   brokenDnBar            = na
var float troughAfterBreakDn     = na
var int   troughAfterBreakDnBar  = na
var bool  isChochDn              = false

// Tracking cực trị
var float lowestBetweenSH     = na
var int   lowestBetweenSHBar  = na
var float highestBetweenSL    = na
var int   highestBetweenSLBar = na

var bool skipAutoSH = false
var bool skipAutoSL = false

// Flags vẽ
var bool  drawBosUp   = false
var bool  drawBosDn   = false
var bool  drawChochUp = false
var bool  drawChochDn = false
var float drawLineLevel = na
var int   drawLineBar   = na

// ═══════════════════════════════════════════
// STEP 2: TRADE QUALITY
// ═══════════════════════════════════════════
var float swingHigh_fib = na
var float swingLow_fib  = na
var int   fibStartBar   = na

var float eq50          = na
var float discountLevel = na
var float premiumLevel  = na

var bool inDiscountZone = false
var bool inPremiumZone  = false

var box fibBox = na

// ══════════════════════════════════════════
// NẾN XÁC NHẬN
// ══════════════════════════════════════════
isConfirmHigh = close < low[1]
isConfirmLow  = close > high[1]

// ══════════════════════════════════════════
// TRACKING CỰC TRỊ (mỗi bar)
// ══════════════════════════════════════════
if trend >= 0
    if na(lowestBetweenSH) or low < lowestBetweenSH
        lowestBetweenSH    := low
        lowestBetweenSHBar := bar_index

if trend <= 0
    if na(highestBetweenSL) or high > highestBetweenSL
        highestBetweenSL    := high
        highestBetweenSLBar := bar_index

// ══════════════════════════════════════════
// UPTREND LOGIC
// ══════════════════════════════════════════
if trend >= 0
    // ── Phá đỉnh ──
    if not waitPullbackUp and not na(lastSH)
        if close > lastSH
            waitPullbackUp      := true
            brokenUpLevel       := lastSH
            brokenUpBar         := lastSHBar
            peakAfterBreakUp    := high
            peakAfterBreakUpBar := bar_index
            isChochUp           := false

    // ── Chờ pullback xác nhận SH ──
    if waitPullbackUp
        if high > peakAfterBreakUp
            peakAfterBreakUp    := high
            peakAfterBreakUpBar := bar_index

        if isConfirmHigh
            waitPullbackUp := false

            // SH cũ → prev
            prevSH    := lastSH
            prevSHBar := lastSHBar

            // SH mới = peak sau breakout (luôn gán)
            lastSH    := peakAfterBreakUp
            lastSHBar := peakAfterBreakUpBar

            // SL tự động = lowest giữa 2 SH
            if skipAutoSL
                skipAutoSL := false
            else
                prevSL    := lastSL
                prevSLBar := lastSLBar
                lastSL    := lowestBetweenSH
                lastSLBar := lowestBetweenSHBar

                // Vẽ SL
                if showSwingHL and not na(lastSL)
                    label.new(lastSLBar, lastSL, "SL", style=label.style_label_up, color=color.new(colorSL, 70), textcolor=colorSL, size=size.tiny)

            // Vẽ SH (luôn vẽ)
            if showSwingHL
                label.new(lastSHBar, lastSH, "SH", style=label.style_label_down, color=color.new(colorSH, 70), textcolor=colorSH, size=size.tiny)

            if showConfirm
                label.new(bar_index, high, "✓", style=label.style_label_down, color=color.new(colorSH, 85), textcolor=colorSH, size=size.tiny)

            if isChochUp
                drawChochUp := true
            else
                drawBosUp := true
            drawLineLevel := brokenUpLevel
            drawLineBar   := brokenUpBar
            trend := 1

            // ═══ STEP 2: Cập nhật Fib levels cho UPTREND ═══
            swingHigh_fib := lastSH
            swingLow_fib  := lastSL
            fibStartBar   := bar_index
            
            // Tính levels
            float swingRange = swingHigh_fib - swingLow_fib
            eq50          := swingLow_fib + (swingRange * 0.5)
            discountLevel := swingLow_fib + (swingRange * (fibThreshold / 100.0))
            premiumLevel  := na  // Uptrend không cần premium

            // Reset tracking
            lowestBetweenSH    := low
            lowestBetweenSHBar := bar_index

    // ── ChoCh DOWN: phá SL trong uptrend ──
    if not waitPullbackDn and not na(lastSL) and trend == 1
        if close < lastSL
            waitPullbackDn        := true
            brokenDnLevel         := lastSL
            brokenDnBar           := lastSLBar
            troughAfterBreakDn    := low
            troughAfterBreakDnBar := bar_index
            isChochDn             := true
            skipAutoSH            := true

            waitPullbackUp := false
            trend := -1

            highestBetweenSL    := high
            highestBetweenSLBar := bar_index

// ══════════════════════════════════════════
// DOWNTREND LOGIC
// ══════════════════════════════════════════
if trend == -1
    // ── Phá đáy ──
    if not waitPullbackDn and not na(lastSL)
        if close < lastSL
            waitPullbackDn        := true
            brokenDnLevel         := lastSL
            brokenDnBar           := lastSLBar
            troughAfterBreakDn    := low
            troughAfterBreakDnBar := bar_index
            isChochDn             := false

    // ── Chờ pullback xác nhận SL ──
    if waitPullbackDn
        if low < troughAfterBreakDn
            troughAfterBreakDn    := low
            troughAfterBreakDnBar := bar_index

        if isConfirmLow
            waitPullbackDn := false

            // SL cũ → prev
            prevSL    := lastSL
            prevSLBar := lastSLBar

            // SL mới = trough sau breakout (luôn gán)
            lastSL    := troughAfterBreakDn
            lastSLBar := troughAfterBreakDnBar

            // SH tự động = highest giữa 2 SL
            if skipAutoSH
                skipAutoSH := false
            else
                prevSH    := lastSH
                prevSHBar := lastSHBar
                lastSH    := highestBetweenSL
                lastSHBar := highestBetweenSLBar

                // Vẽ SH
                if showSwingHL and not na(lastSH)
                    label.new(lastSHBar, lastSH, "SH", style=label.style_label_down, color=color.new(colorSH, 70), textcolor=colorSH, size=size.tiny)

            // Vẽ SL (luôn vẽ)
            if showSwingHL
                label.new(lastSLBar, lastSL, "SL", style=label.style_label_up, color=color.new(colorSL, 70), textcolor=colorSL, size=size.tiny)

            if showConfirm
                label.new(bar_index, low, "✓", style=label.style_label_up, color=color.new(colorSL, 85), textcolor=colorSL, size=size.tiny)

            if isChochDn
                drawChochDn := true
            else
                drawBosDn := true
            drawLineLevel := brokenDnLevel
            drawLineBar   := brokenDnBar
            trend := -1

            // ═══ STEP 2: Cập nhật Fib levels cho DOWNTREND ═══
            swingHigh_fib := lastSH
            swingLow_fib  := lastSL
            fibStartBar   := bar_index
            
            // Tính levels
            float swingRange = swingHigh_fib - swingLow_fib
            eq50          := swingLow_fib + (swingRange * 0.5)
            premiumLevel  := swingHigh_fib - (swingRange * (fibThreshold / 100.0))
            discountLevel := na  // Downtrend không cần discount

            // Reset tracking
            highestBetweenSL    := high
            highestBetweenSLBar := bar_index

    // ── ChoCh UP: phá SH trong downtrend ──
    if not waitPullbackUp and not na(lastSH) and trend == -1
        if close > lastSH
            waitPullbackUp      := true
            brokenUpLevel       := lastSH
            brokenUpBar         := lastSHBar
            peakAfterBreakUp    := high
            peakAfterBreakUpBar := bar_index
            isChochUp           := true
            skipAutoSL          := true

            waitPullbackDn := false
            trend := 1

            lowestBetweenSH    := low
            lowestBetweenSHBar := bar_index

// ══════════════════════════════════════════
// INIT
// ══════════════════════════════════════════
if trend == 0
    pivotH = ta.pivothigh(high, swingLen, swingLen)
    pivotL = ta.pivotlow(low, swingLen, swingLen)

    if not na(pivotH)
        if na(lastSH) or pivotH > lastSH
            prevSH    := lastSH
            prevSHBar := lastSHBar
            lastSH    := pivotH
            lastSHBar := bar_index - swingLen
            if showSwingHL
                label.new(lastSHBar, lastSH, "SH", style=label.style_label_down, color=color.new(color.gray, 70), textcolor=color.gray, size=size.tiny)

    if not na(pivotL)
        if na(lastSL) or pivotL < lastSL
            prevSL    := lastSL
            prevSLBar := lastSLBar
            lastSL    := pivotL
            lastSLBar := bar_index - swingLen
            if showSwingHL
                label.new(lastSLBar, lastSL, "SL", style=label.style_label_up, color=color.new(color.gray, 70), textcolor=color.gray, size=size.tiny)

    if not na(lastSH) and not na(lastSL)
        if not na(prevSH) and lastSH > prevSH
            trend := 1
            lowestBetweenSH    := low
            lowestBetweenSHBar := bar_index
        else if not na(prevSL) and lastSL < prevSL
            trend := -1
            highestBetweenSL    := high
            highestBetweenSLBar := bar_index

// ══════════════════════════════════════════
// VẼ BOS / CHOCH
// ══════════════════════════════════════════
if showBosChoch and not na(drawLineBar)
    midBar = math.round(math.avg(drawLineBar, bar_index))

    if drawBosUp
        line.new(drawLineBar, drawLineLevel, bar_index, drawLineLevel, color=colorBoS, style=line.style_dashed, width=1)
        label.new(midBar, drawLineLevel, "BoS ↑", color=color.new(color.black, 100), textcolor=colorBoS, style=label.style_none, size=size.small)

    if drawBosDn
        line.new(drawLineBar, drawLineLevel, bar_index, drawLineLevel, color=colorBoS, style=line.style_dashed, width=1)
        label.new(midBar, drawLineLevel, "BoS ↓", color=color.new(color.black, 100), textcolor=colorBoS, style=label.style_none, size=size.small)

    if drawChochUp
        line.new(drawLineBar, drawLineLevel, bar_index, drawLineLevel, color=colorChoCh, style=line.style_dotted, width=2)
        label.new(midBar, drawLineLevel, "ChoCh ↑", color=color.new(color.black, 100), textcolor=colorChoCh, style=label.style_none, size=size.small)

    if drawChochDn
        line.new(drawLineBar, drawLineLevel, bar_index, drawLineLevel, color=colorChoCh, style=line.style_dotted, width=2)
        label.new(midBar, drawLineLevel, "ChoCh ↓", color=color.new(color.black, 100), textcolor=colorChoCh, style=label.style_none, size=size.small)

drawBosUp     := false
drawBosDn     := false
drawChochUp   := false
drawChochDn   := false
drawLineLevel := na
drawLineBar   := na

// ══════════════════════════════════════════
// STEP 2: VẼ VÙNG DISCOUNT / PREMIUM
// ══════════════════════════════════════════
box.delete(fibBox)

if showFibZone and not na(swingHigh_fib) and not na(swingLow_fib)
    if trend == 1 and not na(discountLevel)
        // UPTREND: Vẽ vùng Discount (từ 50% → 100% = SL)
        fibBox := box.new(fibStartBar, discountLevel, bar_index + 10, swingLow_fib, 
                          border_color=color.new(colorDiscount, 100), 
                          bgcolor=colorDiscount,
                          text="Discount ≥" + str.tostring(fibThreshold, "#") + "%",
                          text_color=colorSH,
                          text_size=size.tiny,
                          text_halign=text.align_right,
                          text_valign=text.align_top)
        
        // Kiểm tra giá có trong vùng Discount không
        inDiscountZone := close <= discountLevel
        inPremiumZone  := false
        
    else if trend == -1 and not na(premiumLevel)
        // DOWNTREND: Vẽ vùng Premium (từ 0% = SH → 50%)
        fibBox := box.new(fibStartBar, swingHigh_fib, bar_index + 10, premiumLevel,
                          border_color=color.new(colorPremium, 100),
                          bgcolor=colorPremium,
                          text="Premium ≥" + str.tostring(fibThreshold, "#") + "%",
                          text_color=colorSL,
                          text_size=size.tiny,
                          text_halign=text.align_right,
                          text_valign=text.align_bottom)
        
        // Kiểm tra giá có trong vùng Premium không
        inPremiumZone  := close >= premiumLevel
        inDiscountZone := false

// ══════════════════════════════════════════
// VẼ ĐƯỜNG EQUILIBRIUM (50%)
// ══════════════════════════════════════════
var line eqLine = na
if showEQ and not na(eq50)
    line.delete(eqLine)
    eqLine := line.new(fibStartBar, eq50, bar_index + 10, eq50, 
                       color=color.new(color.gray, 50), 
                       style=line.style_dotted, 
                       width=1)
    if barstate.islast
        label.new(bar_index + 5, eq50, "EQ 50%", 
                  style=label.style_none, 
                  color=color.new(color.black, 100), 
                  textcolor=color.gray, 
                  size=size.tiny)

// ══════════════════════════════════════════
// ĐƯỜNG MỨC CHỜ PHÁ VỠ
// ══════════════════════════════════════════
var line levelHighLine = na
var line levelLowLine  = na

if showLevels
    line.delete(levelHighLine)
    line.delete(levelLowLine)

    if not na(lastSH)
        levelHighLine := line.new(lastSHBar, lastSH, bar_index + 5, lastSH, color=color.new(colorSH, 60), style=line.style_dotted, width=1)
    if not na(lastSL)
        levelLowLine := line.new(lastSLBar, lastSL, bar_index + 5, lastSL, color=color.new(colorSL, 60), style=line.style_dotted, width=1)

// ══════════════════════════════════════════
// BẢNG TRẠNG THÁI
// ══════════════════════════════════════════
var table tbl = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 85), border_width=1, border_color=color.new(color.white, 80))

if barstate.islast
    trendStr = trend == 1 ? "🟢 BULLISH" : trend == -1 ? "🔴 BEARISH" : "⚪ INIT"
    shStr    = not na(lastSH) ? str.tostring(lastSH, "#.##") : "—"
    slStr    = not na(lastSL) ? str.tostring(lastSL, "#.##") : "—"

    table.cell(tbl, 0, 0, "STEP 2", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 0, "TRADE QUALITY", text_color=color.yellow, text_size=size.small)

    table.cell(tbl, 0, 1, "Trend", text_color=color.gray, text_size=size.tiny)
    table.cell(tbl, 1, 1, trendStr, text_color=color.white, text_size=size.tiny)

    table.cell(tbl, 0, 2, "Swing High", text_color=color.gray, text_size=size.tiny)
    table.cell(tbl, 1, 2, shStr, text_color=colorSH, text_size=size.tiny)

    table.cell(tbl, 0, 3, "Swing Low", text_color=color.gray, text_size=size.tiny)
    table.cell(tbl, 1, 3, slStr, text_color=colorSL, text_size=size.tiny)

    table.cell(tbl, 0, 4, "EQ 50%", text_color=color.gray, text_size=size.tiny)
    eqStr = not na(eq50) ? str.tostring(eq50, "#.##") : "—"
    table.cell(tbl, 1, 4, eqStr, text_color=color.gray, text_size=size.tiny)

    table.cell(tbl, 0, 5, "Trade Quality", text_color=color.gray, text_size=size.tiny)
    qualityStr = ""
    if trend == 1
        if inDiscountZone
            qualityStr := "✓ Discount (" + str.tostring(fibThreshold, "#") + "%+)"
        else
            qualityStr := "✗ Chờ Discount"
    else if trend == -1
        if inPremiumZone
            qualityStr := "✓ Premium (" + str.tostring(fibThreshold, "#") + "%+)"
        else
            qualityStr := "✗ Chờ Premium"
    else
        qualityStr := "—"
    
    qualityColor = (inDiscountZone and trend == 1) or (inPremiumZone and trend == -1) ? color.lime : color.orange
    table.cell(tbl, 1, 5, qualityStr, text_color=qualityColor, text_size=size.tiny)

    table.cell(tbl, 0, 6, "Đang tìm", text_color=color.gray, text_size=size.tiny)
    seekStr = trend == 1 ? "SH tiếp (phá " + shStr + ")" : trend == -1 ? "SL tiếp (phá " + slStr + ")" : "Chờ xác định trend"
    table.cell(tbl, 1, 6, seekStr, text_color=color.white, text_size=size.tiny)

    table.cell(tbl, 0, 7, "Trạng thái", text_color=color.gray, text_size=size.tiny)
    stateStr = ""
    if waitPullbackUp
        stateStr := "Phá đỉnh → chờ pullback ✓"
    else if waitPullbackDn
        stateStr := "Phá đáy → chờ pullback ✓"
    else
        stateStr := "Chờ phá vỡ"
    table.cell(tbl, 1, 7, stateStr, text_color=color.orange, text_size=size.tiny)

// ══════════════════════════════════════════
// EMA 200
// ══════════════════════════════════════════
ema200 = ta.ema(close, emaLen)
plot(ema200, "EMA 200", color=emaColor, linewidth=2)

// ══════════════════════════════════════════
bgcolor(trend == 1 ? color.new(colorSH, 95) : trend == -1 ? color.new(colorSL, 95) : na)
