// This Pine Script™ source code is subject to the terms of the Mozilla Public License 2.0
// https://mozilla.org/MPL/2.0/
// © SMC Strategy - MS#1 (3-Step System)
//
// Step 1: Cấu trúc thị trường (Swing High/Low, BoS, ChoCh)
// Step 2: Trade Quality (Discount / Premium zones)
// Step 3: Entry Signal (Nến xác nhận đầu tiên + Sweep)
//
// FIX v3: Auto SH/SL dùng ta.lowest/ta.highest scan đúng khoảng
//         giữa 2 swing points, không phụ thuộc vào thời điểm reset

//@version=6
indicator("Market Structure - v3", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=100)

// ════════════════════════════════════════════════════════════
// ① INPUTS
// ════════════════════════════════════════════════════════════

grp_struct = "═══ STEP 1 · CẤU TRÚC THỊ TRƯỜNG ═══"
swingLen      = input.int(5,    "Swing Length",            minval=2, maxval=20, group=grp_struct)
showSwingHL   = input.bool(true,"Hiện Swing High / Low",                        group=grp_struct)
showBos       = input.bool(true,"Hiện BoS",                                      group=grp_struct)
showChoch     = input.bool(true,"Hiện ChoCh",                                    group=grp_struct)
showConfirm   = input.bool(true,"Hiện nến xác nhận",                            group=grp_struct)
showLevels    = input.bool(true,"Hiện đường chờ phá vỡ",                        group=grp_struct)

grp_ema = "═══ EMA ═══"
emaLen        = input.int(200,  "EMA Length", minval=50, maxval=500, group=grp_ema)
emaColor      = input.color(color.new(#9c9c9c, 0), "Màu EMA",       group=grp_ema)

grp_color = "═══ MÀU SẮC ═══"
colorSH       = input.color(color.new(#089981, 0),  "Swing High",          group=grp_color)
colorSL       = input.color(color.new(#F23645, 0),  "Swing Low",           group=grp_color)
colorBoS      = input.color(color.new(#2962FF, 0),  "BoS",                 group=grp_color)
colorChoCh    = input.color(color.new(#FF6D00, 0),  "ChoCh",               group=grp_color)
colorDiscount = input.color(color.new(#089981, 85), "Vùng Discount (Buy)", group=grp_color)
colorPremium  = input.color(color.new(#F23645, 85), "Vùng Premium (Sell)", group=grp_color)

grp_quality = "═══ STEP 2 · TRADE QUALITY ═══"
showFibZone   = input.bool(true,  "Hiện vùng Discount/Premium",                       group=grp_quality)
fibThreshold  = input.float(50.0, "Ngưỡng % (Discount/Premium)", minval=0, maxval=100, step=5, group=grp_quality)
showEQ        = input.bool(true,  "Hiện đường Equilibrium (50%)",                     group=grp_quality)

grp_entry = "═══ STEP 3 · ENTRY SIGNAL ═══"
showEntrySignal = input.bool(true,  "Hiện tín hiệu Entry", group=grp_entry)
enableAlerts    = input.bool(true,  "Bật Alert",           group=grp_entry)
colorBuy        = input.color(color.new(#00897B, 0), "Màu BUY",  group=grp_entry)
colorSell       = input.color(color.new(#E53935, 0), "Màu SELL", group=grp_entry)

// ════════════════════════════════════════════════════════════
// ② STATE VARIABLES
// ════════════════════════════════════════════════════════════

// ── Step 1: Market Structure ─────────────────────────────────
var int trend = 0

var float lastSH    = na
var int   lastSHBar = na
var float prevSH    = na
var int   prevSHBar = na

var float lastSL    = na
var int   lastSLBar = na
var float prevSL    = na
var int   prevSLBar = na

// Chờ pullback để xác nhận swing mới (BoS / ChoCh)
var bool  waitPullbackUp      = false
var float brokenUpLevel       = na
var int   brokenUpBar         = na
var float peakAfterBreakUp    = na
var int   peakAfterBreakUpBar = na
var bool  isChochUp           = false

var bool  waitPullbackDn         = false
var float brokenDnLevel          = na
var int   brokenDnBar            = na
var float troughAfterBreakDn     = na
var int   troughAfterBreakDnBar  = na
var bool  isChochDn              = false

var bool skipAutoSH = false
var bool skipAutoSL = false

// Draw flags: set trong Step 1, vẽ trong DRAWING section
var bool  drawBosUp      = false
var bool  drawBosDn      = false
var bool  drawChochUp    = false
var bool  drawChochDn    = false
var float drawLineLevel  = na
var int   drawLineBar    = na
var int   drawLineEndBar = na

// ── Step 2: Trade Quality ─────────────────────────────────────
var float swingHigh_fib = na
var float swingLow_fib  = na
var int   fibStartBar   = na

var float eq50          = na
var float discountLevel = na
var float premiumLevel  = na

var bool inDiscountZone = false
var bool inPremiumZone  = false

var box fibBox = na

// ── Step 3: Entry Signal ──────────────────────────────────────
// Đã vào vùng chưa
var bool hasEnteredDiscount = false
var bool hasEnteredPremium  = false

// Setup còn valid không (nếu miss nến đầu → invalid)
var bool setupBuyValid  = true
var bool setupSellValid = true

// Swing mới đã được xác nhận chưa (sau ChoCh cần có pullback)
var bool newSwingConfirmed = false

// Đã check nến xác nhận đầu tiên chưa
var bool checkedFirstBuy  = false
var bool checkedFirstSell = false

// Số lượng trigger đã fire
var int buyTriggerCount  = 0
var int sellTriggerCount = 0

// Predicted low/high = cực trị trước nến confirm đầu tiên
var float predictedLow  = na
var float predictedHigh = na

// Cực trị hiện tại khi trong vùng (để tính predicted)
var float currentLowInDiscount  = na
var float currentHighInPremium  = na

// Sweep đã xảy ra sau #1 chưa (sweep và confirm có thể cùng 1 nến — ví dụ nến hammer)
var bool sweepOccurredBuy  = false
var bool sweepOccurredSell = false

// Cực trị trong quá trình sweep (dùng làm SL mới cho #2)
var float sweepLowBuy   = na
var float sweepHighSell = na

// ════════════════════════════════════════════════════════════
// ③ HELPER FUNCTIONS
// ════════════════════════════════════════════════════════════

// Tìm đáy thấp nhất trong khoảng [fromBar, toBar]
findLowestInRange(int fromBar, int toBar) =>
    float minVal = na
    int   minIdx = na
    int   lookback    = bar_index - fromBar
    int   lookbackEnd = bar_index - toBar
    if lookback >= 0 and lookbackEnd >= 0
        for i = lookbackEnd to lookback
            if i >= 0 and i < bar_index
                float val = low[i]
                if na(minVal) or val < minVal
                    minVal := val
                    minIdx := bar_index - i
    [minVal, minIdx]

// Tìm đỉnh cao nhất trong khoảng [fromBar, toBar]
findHighestInRange(int fromBar, int toBar) =>
    float maxVal = na
    int   maxIdx = na
    int   lookback    = bar_index - fromBar
    int   lookbackEnd = bar_index - toBar
    if lookback >= 0 and lookbackEnd >= 0
        for i = lookbackEnd to lookback
            if i >= 0 and i < bar_index
                float val = high[i]
                if na(maxVal) or val > maxVal
                    maxVal := val
                    maxIdx := bar_index - i
    [maxVal, maxIdx]

// ════════════════════════════════════════════════════════════
// ④ BASE CALCULATIONS (mỗi bar)
// ════════════════════════════════════════════════════════════

atr    = ta.atr(14)
ema200 = ta.ema(close, emaLen)

// Nến xác nhận đảo chiều
isConfirmHigh = close < low[1]   // Nến xác nhận đỉnh (bắt đầu giảm)
isConfirmLow  = close > high[1]  // Nến xác nhận đáy (bắt đầu tăng)

// ════════════════════════════════════════════════════════════
// ① STEP 1: MARKET STRUCTURE
// ════════════════════════════════════════════════════════════

// ── UPTREND: Phá đỉnh / ChoCh xuống ─────────────────────────
if trend >= 0

    // Phá đỉnh → bắt đầu chờ pullback
    if not waitPullbackUp and not na(lastSH)
        if close > lastSH
            waitPullbackUp      := true
            brokenUpLevel       := lastSH
            brokenUpBar         := lastSHBar
            peakAfterBreakUp    := high
            peakAfterBreakUpBar := bar_index
            isChochUp           := false

    // Chờ pullback → xác nhận SH mới
    if waitPullbackUp
        if high > peakAfterBreakUp
            peakAfterBreakUp    := high
            peakAfterBreakUpBar := bar_index

        if isConfirmHigh
            waitPullbackUp := false

            // SH cũ → prev, SH mới = peak sau breakout
            prevSH    := lastSH
            prevSHBar := lastSHBar
            lastSH    := peakAfterBreakUp
            lastSHBar := peakAfterBreakUpBar

            // Auto SL: đáy thấp nhất giữa SH cũ và SH mới
            if skipAutoSL
                skipAutoSL := false
            else
                prevSL    := lastSL
                prevSLBar := lastSLBar
                [foundLow, foundLowBar] = findLowestInRange(prevSHBar + 1, lastSHBar)
                lastSL    := foundLow
                lastSLBar := foundLowBar
                if showSwingHL and not na(lastSL)
                    label.new(lastSLBar, lastSL - atr * 0.3, "▲", style=label.style_none, color=color.new(colorSL, 100), textcolor=colorSL, size=size.normal)

            if showSwingHL
                label.new(lastSHBar, lastSH, "▼", style=label.style_none, color=color.new(colorSH, 100), textcolor=colorSH, size=size.normal)
            if showConfirm
                label.new(bar_index, high, "✓", style=label.style_label_down, color=color.new(colorSH, 85), textcolor=colorSH, size=size.tiny)

            // Set draw flags cho BoS / ChoCh
            drawBosUp   := not isChochUp
            drawChochUp := isChochUp
            drawLineLevel  := brokenUpLevel
            drawLineBar    := brokenUpBar
            drawLineEndBar := lastSHBar

            // ── Step 2: Cập nhật Fib levels cho uptrend ──
            swingHigh_fib := lastSH
            swingLow_fib  := lastSL
            fibStartBar   := bar_index
            float swingRange = swingHigh_fib - swingLow_fib
            eq50          := swingLow_fib + swingRange * 0.5
            discountLevel := swingLow_fib + swingRange * (fibThreshold / 100.0)
            premiumLevel  := na  // Uptrend không cần premium

            // ── Step 3: Reset tracking cho sóng mới ──
            hasEnteredDiscount   := false
            setupBuyValid        := true
            checkedFirstBuy      := false
            buyTriggerCount      := 0
            predictedLow         := na
            currentLowInDiscount := na
            sweepOccurredBuy     := false
            sweepLowBuy          := na
            newSwingConfirmed    := true

    // ChoCh DOWN: phá SL trong uptrend → đổi về downtrend
    if not waitPullbackDn and not na(lastSL) and trend == 1
        if close < lastSL
            waitPullbackDn        := true
            brokenDnLevel         := lastSL
            brokenDnBar           := lastSLBar
            troughAfterBreakDn    := low
            troughAfterBreakDnBar := bar_index
            isChochDn             := true
            skipAutoSH            := true
            waitPullbackUp        := false
            trend                 := -1

            // ── Step 3: ChoCh → reset toàn bộ tracking ──
            newSwingConfirmed    := false
            hasEnteredPremium    := false
            setupSellValid       := true
            checkedFirstSell     := false
            sellTriggerCount     := 0
            predictedHigh        := na
            currentHighInPremium := na
            sweepOccurredSell    := false
            sweepHighSell        := na

            hasEnteredDiscount   := false
            setupBuyValid        := true
            checkedFirstBuy      := false
            buyTriggerCount      := 0
            predictedLow         := na
            currentLowInDiscount := na
            sweepOccurredBuy     := false
            sweepLowBuy          := na

// ── DOWNTREND: Phá đáy / ChoCh lên ──────────────────────────
if trend == -1

    // Phá đáy → bắt đầu chờ pullback
    if not waitPullbackDn and not na(lastSL)
        if close < lastSL
            waitPullbackDn        := true
            brokenDnLevel         := lastSL
            brokenDnBar           := lastSLBar
            troughAfterBreakDn    := low
            troughAfterBreakDnBar := bar_index
            isChochDn             := false

    // Chờ pullback → xác nhận SL mới
    if waitPullbackDn
        if low < troughAfterBreakDn
            troughAfterBreakDn    := low
            troughAfterBreakDnBar := bar_index

        if isConfirmLow
            waitPullbackDn := false

            // SL cũ → prev, SL mới = trough sau breakout
            prevSL    := lastSL
            prevSLBar := lastSLBar
            lastSL    := troughAfterBreakDn
            lastSLBar := troughAfterBreakDnBar

            // Auto SH: đỉnh cao nhất giữa SL cũ và SL mới
            if skipAutoSH
                skipAutoSH := false
            else
                prevSH    := lastSH
                prevSHBar := lastSHBar
                [foundHigh, foundHighBar] = findHighestInRange(prevSLBar + 1, lastSLBar)
                lastSH    := foundHigh
                lastSHBar := foundHighBar
                if showSwingHL and not na(lastSH)
                    label.new(lastSHBar, lastSH, "▼", style=label.style_none, color=color.new(colorSH, 100), textcolor=colorSH, size=size.normal)

            if showSwingHL
                label.new(lastSLBar, lastSL - atr * 0.3, "▲", style=label.style_none, color=color.new(colorSL, 100), textcolor=colorSL, size=size.normal)
            if showConfirm
                label.new(bar_index, low, "✓", style=label.style_label_up, color=color.new(colorSL, 85), textcolor=colorSL, size=size.tiny)

            // Set draw flags cho BoS / ChoCh
            drawBosDn   := not isChochDn
            drawChochDn := isChochDn
            drawLineLevel  := brokenDnLevel
            drawLineBar    := brokenDnBar
            drawLineEndBar := lastSLBar

            // ── Step 2: Cập nhật Fib levels cho downtrend ──
            swingHigh_fib := lastSH
            swingLow_fib  := lastSL
            fibStartBar   := bar_index
            float swingRange = swingHigh_fib - swingLow_fib
            eq50         := swingLow_fib + swingRange * 0.5
            premiumLevel := swingHigh_fib - swingRange * (fibThreshold / 100.0)
            discountLevel := na  // Downtrend không cần discount

            // ── Step 3: Reset tracking cho sóng mới ──
            hasEnteredPremium    := false
            setupSellValid       := true
            checkedFirstSell     := false
            sellTriggerCount     := 0
            predictedHigh        := na
            currentHighInPremium := na
            sweepOccurredSell    := false
            sweepHighSell        := na
            newSwingConfirmed    := true

    // ChoCh UP: phá SH trong downtrend → đổi về uptrend
    if not waitPullbackUp and not na(lastSH) and trend == -1
        if close > lastSH
            waitPullbackUp      := true
            brokenUpLevel       := lastSH
            brokenUpBar         := lastSHBar
            peakAfterBreakUp    := high
            peakAfterBreakUpBar := bar_index
            isChochUp           := true
            skipAutoSL          := true
            waitPullbackDn      := false
            trend               := 1

            // ── Step 3: ChoCh → reset toàn bộ tracking ──
            newSwingConfirmed    := false
            hasEnteredDiscount   := false
            setupBuyValid        := true
            checkedFirstBuy      := false
            buyTriggerCount      := 0
            predictedLow         := na
            currentLowInDiscount := na
            sweepOccurredBuy     := false
            sweepLowBuy          := na

            hasEnteredPremium    := false
            setupSellValid       := true
            checkedFirstSell     := false
            sellTriggerCount     := 0
            predictedHigh        := na
            currentHighInPremium := na
            sweepOccurredSell    := false
            sweepHighSell        := na

// ── INIT: Xác định trend ban đầu (chạy khi trend == 0) ───────
// QUAN TRỌNG: giữ sau uptrend/downtrend để đảm bảo thứ tự thực thi đúng
if trend == 0
    pivotH = ta.pivothigh(high, swingLen, swingLen)
    pivotL = ta.pivotlow(low, swingLen, swingLen)

    if not na(pivotH)
        if na(lastSH) or pivotH > lastSH
            prevSH    := lastSH
            prevSHBar := lastSHBar
            lastSH    := pivotH
            lastSHBar := bar_index - swingLen
            if showSwingHL
                label.new(lastSHBar, lastSH, "▼", style=label.style_none, color=color.new(color.black, 100), textcolor=color.new(color.orange, 50), size=size.normal)

    if not na(pivotL)
        if na(lastSL) or pivotL < lastSL
            prevSL    := lastSL
            prevSLBar := lastSLBar
            lastSL    := pivotL
            lastSLBar := bar_index - swingLen
            if showSwingHL
                label.new(lastSLBar, lastSL - atr * 0.3, "▲", style=label.style_none, color=color.new(color.black, 100), textcolor=color.new(color.orange, 50), size=size.normal)

    if not na(lastSH) and not na(lastSL)
        if not na(prevSH) and lastSH > prevSH
            trend := 1
        else if not na(prevSL) and lastSL < prevSL
            trend := -1

// ════════════════════════════════════════════════════════════
// ② STEP 2: TRADE QUALITY — ZONE DETECTION
// ════════════════════════════════════════════════════════════
// (Fib level assignments xảy ra inline trong Step 1 ở trên)

if trend == 1 and not na(discountLevel)
    inDiscountZone := low <= discountLevel
    inPremiumZone  := false

    if inDiscountZone and not hasEnteredDiscount
        hasEnteredDiscount   := true
        currentLowInDiscount := low

    if inDiscountZone and not checkedFirstBuy
        if na(currentLowInDiscount) or low < currentLowInDiscount
            currentLowInDiscount := low

else if trend == -1 and not na(premiumLevel)
    inPremiumZone  := high >= premiumLevel
    inDiscountZone := false

    if inPremiumZone and not hasEnteredPremium
        hasEnteredPremium    := true
        currentHighInPremium := high

    if inPremiumZone and not checkedFirstSell
        if na(currentHighInPremium) or high > currentHighInPremium
            currentHighInPremium := high

// ════════════════════════════════════════════════════════════
// ③ STEP 3: ENTRY SIGNAL LOGIC
// ════════════════════════════════════════════════════════════

// ── BUY ─────────────────────────────────────────────────────
if trend == 1 and newSwingConfirmed and setupBuyValid and hasEnteredDiscount

    // Nến xác nhận đầu tiên sau khi vào Discount
    if not checkedFirstBuy and isConfirmLow
        checkedFirstBuy := true
        predictedLow    := currentLowInDiscount

        if close > ema200
            buyTriggerCount := 1
            if showEntrySignal
                label.new(bar_index, low, "#1", style=label.style_label_up, color=colorBuy, textcolor=color.white, size=size.small)
            if enableAlerts
                alert("🟢 BUY #1 | Price: " + str.tostring(close, "#.##") + " | EMA200: " + str.tostring(ema200, "#.##") + " | Predicted Low: " + str.tostring(predictedLow, "#.##"), alert.freq_once_per_bar_close)
        else
            setupBuyValid := false

    // Trigger #2: sweep qua predicted low + confirm đảo chiều (có thể cùng 1 nến)
    else if buyTriggerCount == 1 and not na(predictedLow) and not waitPullbackUp
        if low < predictedLow
            sweepOccurredBuy := true
            sweepLowBuy      := na(sweepLowBuy) or low < sweepLowBuy ? low : sweepLowBuy
        if sweepOccurredBuy and isConfirmLow
            if close > ema200
                buyTriggerCount  := 2
                sweepOccurredBuy := false
                predictedLow     := sweepLowBuy  // SL mới = đáy sweep
                sweepLowBuy      := na
                if showEntrySignal
                    label.new(bar_index, low, "#2", style=label.style_label_up, color=colorBuy, textcolor=color.white, size=size.small)
                if enableAlerts
                    alert("🟢 BUY #2 (Sweep Confirm) | Price: " + str.tostring(close, "#.##") + " | Sweep Low: " + str.tostring(predictedLow, "#.##"), alert.freq_once_per_bar_close)

// ── SELL ─────────────────────────────────────────────────────
if trend == -1 and newSwingConfirmed and setupSellValid and hasEnteredPremium

    // Nến xác nhận đầu tiên sau khi vào Premium
    if not checkedFirstSell and isConfirmHigh
        checkedFirstSell := true
        predictedHigh    := currentHighInPremium

        if close < ema200
            sellTriggerCount := 1
            if showEntrySignal
                label.new(bar_index, high, "#1", style=label.style_label_down, color=colorSell, textcolor=color.white, size=size.small)
            if enableAlerts
                alert("🔴 SELL #1 | Price: " + str.tostring(close, "#.##") + " | EMA200: " + str.tostring(ema200, "#.##") + " | Predicted High: " + str.tostring(predictedHigh, "#.##"), alert.freq_once_per_bar_close)
        else
            setupSellValid := false

    // Trigger #2: sweep qua predicted high + confirm đảo chiều (có thể cùng 1 nến)
    else if sellTriggerCount == 1 and not na(predictedHigh) and not waitPullbackDn
        if high > predictedHigh
            sweepOccurredSell := true
            sweepHighSell     := na(sweepHighSell) or high > sweepHighSell ? high : sweepHighSell
        if sweepOccurredSell and isConfirmHigh
            if close < ema200
                sellTriggerCount  := 2
                sweepOccurredSell := false
                predictedHigh     := sweepHighSell  // SL mới = đỉnh sweep
                sweepHighSell     := na
                if showEntrySignal
                    label.new(bar_index, high, "#2", style=label.style_label_down, color=colorSell, textcolor=color.white, size=size.small)
                if enableAlerts
                    alert("🔴 SELL #2 (Sweep Confirm) | Price: " + str.tostring(close, "#.##") + " | Sweep High: " + str.tostring(predictedHigh, "#.##"), alert.freq_once_per_bar_close)

// ════════════════════════════════════════════════════════════
// DRAWING
// ════════════════════════════════════════════════════════════

// ── EMA 200 ──────────────────────────────────────────────────
plot(ema200, "EMA 200", color=emaColor, linewidth=2)

// ── BoS / ChoCh lines ────────────────────────────────────────
if not na(drawLineBar)
    int endBar = not na(drawLineEndBar) ? drawLineEndBar : bar_index
    midBar = math.round(math.avg(drawLineBar, endBar))

    if showBos
        if drawBosUp
            line.new(drawLineBar, drawLineLevel, endBar, drawLineLevel, color=colorBoS, style=line.style_dashed, width=1)
            label.new(midBar, drawLineLevel, "BoS ↑", color=color.new(color.black, 100), textcolor=colorBoS, style=label.style_none, size=size.small)
        if drawBosDn
            line.new(drawLineBar, drawLineLevel, endBar, drawLineLevel, color=colorBoS, style=line.style_dashed, width=1)
            label.new(midBar, drawLineLevel, "BoS ↓", color=color.new(color.black, 100), textcolor=colorBoS, style=label.style_none, size=size.small)
    if showChoch
        if drawChochUp
            line.new(drawLineBar, drawLineLevel, endBar, drawLineLevel, color=colorChoCh, style=line.style_dotted, width=2)
            label.new(midBar, drawLineLevel, "ChoCh ↑", color=color.new(color.black, 100), textcolor=colorChoCh, style=label.style_none, size=size.small)
        if drawChochDn
            line.new(drawLineBar, drawLineLevel, endBar, drawLineLevel, color=colorChoCh, style=line.style_dotted, width=2)
            label.new(midBar, drawLineLevel, "ChoCh ↓", color=color.new(color.black, 100), textcolor=colorChoCh, style=label.style_none, size=size.small)

// Draw flag reset (phải ngay sau khi vẽ BoS/ChoCh)
drawBosUp      := false
drawBosDn      := false
drawChochUp    := false
drawChochDn    := false
drawLineLevel  := na
drawLineBar    := na
drawLineEndBar := na

// ── Vùng Discount / Premium (box) ────────────────────────────
box.delete(fibBox)
if showFibZone and not na(swingHigh_fib) and not na(swingLow_fib)
    if trend == 1 and not na(discountLevel)
        fibBox := box.new(fibStartBar, discountLevel, bar_index + 10, swingLow_fib,
                          border_color=color.new(colorDiscount, 100),
                          bgcolor=colorDiscount,
                          text="Discount ≥" + str.tostring(fibThreshold, "#") + "%",
                          text_color=colorSH,
                          text_size=size.tiny,
                          text_halign=text.align_right,
                          text_valign=text.align_top)
    else if trend == -1 and not na(premiumLevel)
        fibBox := box.new(fibStartBar, swingHigh_fib, bar_index + 10, premiumLevel,
                          border_color=color.new(colorPremium, 100),
                          bgcolor=colorPremium,
                          text="Premium ≥" + str.tostring(fibThreshold, "#") + "%",
                          text_color=colorSL,
                          text_size=size.tiny,
                          text_halign=text.align_right,
                          text_valign=text.align_bottom)

// ── Đường Equilibrium (50%) ──────────────────────────────────
var line eqLine = na
if showEQ and not na(eq50)
    line.delete(eqLine)
    eqLine := line.new(fibStartBar, eq50, bar_index + 10, eq50,
                       color=color.new(color.gray, 50),
                       style=line.style_dotted,
                       width=1)
    if barstate.islast
        label.new(bar_index + 5, eq50, "EQ 50%",
                  style=label.style_none,
                  color=color.new(color.black, 100),
                  textcolor=color.gray,
                  size=size.tiny)

// ── Đường mức chờ phá vỡ (SH / SL hiện tại) ─────────────────
var line levelHighLine = na
var line levelLowLine  = na
if showLevels
    line.delete(levelHighLine)
    line.delete(levelLowLine)
    if not na(lastSH)
        levelHighLine := line.new(lastSHBar, lastSH, bar_index + 5, lastSH, color=color.new(colorSH, 60), style=line.style_dotted, width=1)
    if not na(lastSL)
        levelLowLine  := line.new(lastSLBar, lastSL, bar_index + 5, lastSL, color=color.new(colorSL, 60), style=line.style_dotted, width=1)

// ── Bảng trạng thái ──────────────────────────────────────────
var table tbl = table.new(position.top_right, 2, 11, bgcolor=color.new(color.black, 85), border_width=1, border_color=color.new(color.white, 80))

if barstate.islast
    trendStr       = trend == 1 ? "🟢 BULLISH" : trend == -1 ? "🔴 BEARISH" : "⚪ INIT"
    shStr          = not na(lastSH) ? str.tostring(lastSH, "#.##") : "—"
    slStr          = not na(lastSL) ? str.tostring(lastSL, "#.##") : "—"
    emaStr         = str.tostring(ema200, "#.##")
    emaStatusColor = close > ema200 ? colorSH : close < ema200 ? colorSL : color.gray
    eqStr          = not na(eq50) ? str.tostring(eq50, "#.##") : "—"

    table.cell(tbl, 0, 0, "MS#1 v3",     text_color=color.white,  text_size=size.small)
    table.cell(tbl, 1, 0, "FIXED SWEEP", text_color=color.yellow, text_size=size.small)

    table.cell(tbl, 0, 1, "Trend",       text_color=color.gray,   text_size=size.tiny)
    table.cell(tbl, 1, 1, trendStr,      text_color=color.white,  text_size=size.tiny)

    table.cell(tbl, 0, 2, "Swing High",  text_color=color.gray,   text_size=size.tiny)
    table.cell(tbl, 1, 2, shStr,         text_color=colorSH,      text_size=size.tiny)

    table.cell(tbl, 0, 3, "Swing Low",   text_color=color.gray,   text_size=size.tiny)
    table.cell(tbl, 1, 3, slStr,         text_color=colorSL,      text_size=size.tiny)

    table.cell(tbl, 0, 4, "EMA 200",     text_color=color.gray,   text_size=size.tiny)
    table.cell(tbl, 1, 4, emaStr,        text_color=emaStatusColor, text_size=size.tiny)

    table.cell(tbl, 0, 5, "EQ 50%",      text_color=color.gray,   text_size=size.tiny)
    table.cell(tbl, 1, 5, eqStr,         text_color=color.gray,   text_size=size.tiny)

    // Setup Valid
    setupStr   = ""
    setupColor = color.white
    if trend == 1
        if not newSwingConfirmed
            setupStr  := "⏳ Chờ pullback xác nhận"
            setupColor := color.orange
        else if not setupBuyValid
            setupStr  := "🚫 Bỏ qua (miss 1st)"
            setupColor := color.red
        else if hasEnteredDiscount
            setupStr  := "✓ Valid"
            setupColor := color.lime
        else
            setupStr  := "⏳ Chờ vào Discount"
            setupColor := color.orange
    else if trend == -1
        if not newSwingConfirmed
            setupStr  := "⏳ Chờ pullback xác nhận"
            setupColor := color.orange
        else if not setupSellValid
            setupStr  := "🚫 Bỏ qua (miss 1st)"
            setupColor := color.red
        else if hasEnteredPremium
            setupStr  := "✓ Valid"
            setupColor := color.lime
        else
            setupStr  := "⏳ Chờ vào Premium"
            setupColor := color.orange
    else
        setupStr  := "—"
        setupColor := color.gray
    table.cell(tbl, 0, 6, "Setup Valid", text_color=color.gray,  text_size=size.tiny)
    table.cell(tbl, 1, 6, setupStr,      text_color=setupColor,  text_size=size.tiny)

    // Trigger count
    triggerStr   = ""
    triggerColor = color.white
    if trend == 1
        if buyTriggerCount == 0
            triggerStr := "0/2 BUY"
        else if buyTriggerCount == 1
            triggerStr  := "1/2 BUY (chờ sweep)"
            triggerColor := color.yellow
        else
            triggerStr  := "2/2 BUY (hết)"
            triggerColor := color.red
    else if trend == -1
        if sellTriggerCount == 0
            triggerStr := "0/2 SELL"
        else if sellTriggerCount == 1
            triggerStr  := "1/2 SELL (chờ sweep)"
            triggerColor := color.yellow
        else
            triggerStr  := "2/2 SELL (hết)"
            triggerColor := color.red
    else
        triggerStr  := "—"
        triggerColor := color.gray
    table.cell(tbl, 0, 7, "Trigger",    text_color=color.gray,   text_size=size.tiny)
    table.cell(tbl, 1, 7, triggerStr,   text_color=triggerColor, text_size=size.tiny)

    // Entry Ready
    entryStr   = ""
    entryColor = color.orange
    if trend == 1
        if not setupBuyValid
            entryStr  := "✗ Setup invalid"
            entryColor := color.red
        else if buyTriggerCount >= 2
            entryStr  := "✗ Hết quota"
            entryColor := color.red
        else if buyTriggerCount == 1
            entryStr  := "⏳ Chờ sweep đáy"
            entryColor := color.yellow
        else if hasEnteredDiscount and close > ema200
            entryStr  := "✓ Chờ nến confirm"
            entryColor := color.lime
        else if hasEnteredDiscount
            entryStr  := "⚠ Close <= EMA200"
        else
            entryStr  := "⏳ Chờ vào Discount"
    else if trend == -1
        if not setupSellValid
            entryStr  := "✗ Setup invalid"
            entryColor := color.red
        else if sellTriggerCount >= 2
            entryStr  := "✗ Hết quota"
            entryColor := color.red
        else if sellTriggerCount == 1
            entryStr  := "⏳ Chờ sweep đỉnh"
            entryColor := color.yellow
        else if hasEnteredPremium and close < ema200
            entryStr  := "✓ Chờ nến confirm"
            entryColor := color.lime
        else if hasEnteredPremium
            entryStr  := "⚠ Close >= EMA200"
        else
            entryStr  := "⏳ Chờ vào Premium"
    else
        entryStr := "—"
    table.cell(tbl, 0, 8, "Entry Ready", text_color=color.gray,  text_size=size.tiny)
    table.cell(tbl, 1, 8, entryStr,      text_color=entryColor,  text_size=size.tiny)

    // SL gợi ý (đáy/đỉnh dự đoán)
    slSuggestStr   = "—"
    slSuggestColor = color.gray
    if trend == 1
        float slVal = not na(predictedLow) ? predictedLow : currentLowInDiscount
        if not na(slVal)
            slSuggestStr   := str.tostring(slVal, "#.##")
            slSuggestColor := colorSL
    else if trend == -1
        float slVal = not na(predictedHigh) ? predictedHigh : currentHighInPremium
        if not na(slVal)
            slSuggestStr   := str.tostring(slVal, "#.##")
            slSuggestColor := colorSH
    table.cell(tbl, 0, 9,  "SL gợi ý",   text_color=color.gray,      text_size=size.tiny)
    table.cell(tbl, 1, 9,  slSuggestStr,  text_color=slSuggestColor,  text_size=size.tiny)

    // Trạng thái chờ
    stateStr = waitPullbackUp ? "Phá đỉnh → chờ pullback ✓" : waitPullbackDn ? "Phá đáy → chờ pullback ✓" : "Chờ phá vỡ"
    table.cell(tbl, 0, 10, "Trạng thái", text_color=color.gray,   text_size=size.tiny)
    table.cell(tbl, 1, 10, stateStr,     text_color=color.orange, text_size=size.tiny)
